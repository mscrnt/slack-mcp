# Slack MCP Server Configuration

# Slack Bot OAuth token (required)
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
# Required scopes for sending: chat:write, chat:write.public, users:read, users:read.email
# Additional scopes for receiving: channels:history, channels:read, search:read
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Email domain for resolving usernames to email addresses
SLACK_EMAIL_DOMAIN=domain.com

# Maximum number of recipients per message (prevents spam)
MAX_RECIPIENTS=10

# Enable receive functionality (reading messages, channels, search)
ENABLE_RECEIVE=false

# Server port for SSE/HTTP transport
MCP_PORT=5000
